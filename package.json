{
  "name": "com.elegoo.sdcp",
  "version": "1.0.0",
  "description": "Homey App for Elegoo 3D Printers using SDCP V3",
  "main": "app.js",
  "author": "<HIDDEN>",
  "repository": {
    "type": "git",
    "url": "https://github.com/snurre66/elegoo-homey.git"
  },
  "bugs": {
    "url": "https://github.com/snurre66/elegoo-homey/issues"
  },
  "keywords": [
    "homey",
    "elegoo",
    "3d printer",
    "sdcp",
    "centauri",
    "carbon"
  ],
  "license": "MIT",
  "scripts": {
    "publish:safe": "node .scripts/homey-publish.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "validate": "npx homey app validate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "eslint": "^7.32.0",
    "eslint-config-athom": "^3.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  }
}
